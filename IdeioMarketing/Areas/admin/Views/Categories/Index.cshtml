@model IdeioMarketing.Areas.Admin.Models.CategoryPageVm
@{
    ViewData["Title"] = "Kategoriler";
}

<link rel="stylesheet" href="~/css/admin-crud.css" asp-append-version="true" />

<div class="container-fluid admin-crud-page px-4">
    <div id="pageAlertArea"></div>

    <div class="admin-hero mb-4">
        <div class="section-kicker">ADMIN PANEL</div>
        <h2>Kategori Yönetimi</h2>
        <p>Kategori kayıtlarını tek ekranda, sayfa yenilenmeden ekleyebilir, güncelleyebilir ve silebilirsin.</p>
    </div>

    <div class="row g-4">
        <div class="col-xl-4">
            <div class="admin-card sticky-card">
                <div class="card-body">
                    <div class="section-kicker">FORM</div>
                    <div class="section-title" id="formTitle">Yeni Kategori Ekle</div>
                    <div class="section-subtitle">Formu doldur ve kaydet. Düzenleme modundaysan kayıt güncellenir.</div>

                    <form id="categoryForm">
                        @Html.AntiForgeryToken()

                        <input type="hidden" id="categoryId" name="Id" value="0" />

                        <div id="formErrorBox" class="alert alert-danger d-none"></div>

                        <div class="mb-3">
                            <label for="categoryName" class="form-label">Kategori Adı</label>
                            <input id="categoryName"
                                   name="Name"
                                   class="form-control"
                                   placeholder="Örn: Sosyal Medya Yönetimi" />
                        </div>

                        <div class="mb-3">
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" id="isPackageMultiSelected" />
                                <label class="form-check-label" for="isPackageMultiSelected">
                                    Paketlerde çoklu seçim aktif
                                </label>
                            </div>
                        </div>

                        <div class="mb-3">
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" id="isSubPackageMultiSelected" />
                                <label class="form-check-label" for="isSubPackageMultiSelected">
                                    Alt paketlerde çoklu seçim aktif
                                </label>
                            </div>
                        </div>

                        <div class="d-flex gap-2 mt-4">
                            <button type="submit" id="btnSave" class="btn btn-primary flex-fill">Kaydet</button>
                            <button type="button" id="btnCancelEdit" class="btn btn-light flex-fill">Temizle</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-xl-8">
            <div class="admin-card">
                <div class="card-body">
                    <div class="top-inline">
                        <div>
                            <div class="section-title mb-0">Mevcut Kategoriler</div>
                            <div class="section-subtitle mb-0">Kayıtları sağ taraftan yönetebilirsin.</div>
                        </div>
                        <div class="count-pill"><span id="categoryCount">@Model.Items.Count</span> kayıt</div>
                    </div>

                    <div class="table-responsive">
                        <table class="table table-modern">
                            <thead>
                                <tr>
                                    <th>Kategori</th>
                                    <th>Paket Çoklu</th>
                                    <th>Alt Paket Çoklu</th>
                                    <th>Paket</th>
                                    <th>Alt Paket</th>
                                    <th>Durum</th>
                                    <th class="text-end">İşlemler</th>
                                </tr>
                            </thead>
                            <tbody id="categoryTableBody">
                                @if (!Model.Items.Any())
                                {
                                    <tr id="emptyRow">
                                        <td colspan="7">
                                            <div class="empty-state">
                                                <h5>Henüz kategori eklenmemiş</h5>
                                                <div>Sol taraftaki formdan ilk kaydı oluşturabilirsin.</div>
                                            </div>
                                        </td>
                                    </tr>
                                }
                                else
                                {
                                    @foreach (var item in Model.Items)
                                    {
                                        var hasRelation = item.PackageCount > 0 || item.SubPackageCount > 0;

                                        <tr id="row-@item.Id" data-row="1">
                                            <td>
                                                <div class="entity-title">@item.Name</div>
                                                <div class="entity-meta">ID: @item.Id</div>
                                            </td>
                                            <td>
                                                @if (item.IsPackageMultiSelected)
                                                {
                                                    <span class="status-ok">Açık</span>
                                                }
                                                else
                                                {
                                                    <span class="status-passive">Kapalı</span>
                                                }
                                            </td>
                                            <td>
                                                @if (item.IsSubPackageMultiSelected)
                                                {
                                                    <span class="status-ok">Açık</span>
                                                }
                                                else
                                                {
                                                    <span class="status-passive">Kapalı</span>
                                                }
                                            </td>
                                            <td>
                                                <span class="badge-soft-dark">@item.PackageCount paket</span>
                                            </td>
                                            <td>
                                                <span class="badge-soft-dark">@item.SubPackageCount alt paket</span>
                                            </td>
                                            <td>
                                                @if (hasRelation)
                                                {
                                                    <span class="status-ok">Kullanımda</span>
                                                }
                                                else
                                                {
                                                    <span class="status-passive">Bağlantı yok</span>
                                                }
                                            </td>
                                            <td class="text-end">
                                                <div class="inline-actions justify-content-end">
                                                    <button type="button"
                                                            class="btn btn-sm btn-outline-primary btn-category-edit"
                                                            data-id="@item.Id">
                                                        Düzenle
                                                    </button>

                                                    <button type="button"
                                                            class="btn btn-sm btn-outline-danger btn-category-delete"
                                                            data-id="@item.Id"
                                                        @(hasRelation ? "disabled" : null)>
                                                        Sil
                                                    </button>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts
{
    <script>
        (function() {
            const form = $('#categoryForm');
            const token = form.find('input[name="__RequestVerificationToken"]').val();
            const tableBody = $('#categoryTableBody');
            const pageAlertArea = $('#pageAlertArea');
            const formErrorBox = $('#formErrorBox');
            const formTitle = $('#formTitle');
            const btnSave = $('#btnSave');
            const btnCancelEdit = $('#btnCancelEdit');
            const categoryCount = $('#categoryCount');

            function escapeHtml(text) {
                if (text === null || text === undefined) return '';
                return String(text)
                    .replaceAll('&', '&amp;')
                    .replaceAll('<', '&lt;')
                    .replaceAll('>', '&gt;')
                    .replaceAll('"', '&quot;')
                    .replaceAll("'", '&#39;');
            }

            function showPageAlert(type, message) {
                const html = `
                        <div class="alert alert-${type} shadow-sm border-0 mb-4">
                            ${escapeHtml(message)}
                        </div>
                    `;
                pageAlertArea.html(html);

                setTimeout(function() {
                    pageAlertArea.find('.alert').fadeOut(300, function() {
                        $(this).remove();
                    });
                }, 3000);
            }

            function showFormErrors(errors) {
                if (!errors || !errors.length) {
                    formErrorBox.addClass('d-none').html('');
                    return;
                }

                const html = `<ul class="mb-0 ps-3">${errors.map(x => `<li>${escapeHtml(x)}</li>`).join('')}</ul>`;
                formErrorBox.removeClass('d-none').html(html);
            }

            function resetForm() {
                $('#categoryId').val(0);
                $('#categoryName').val('');
                $('#isPackageMultiSelected').prop('checked', false);
                $('#isSubPackageMultiSelected').prop('checked', false);
                formTitle.text('Yeni Kategori Ekle');
                btnSave.text('Kaydet');
                showFormErrors([]);
            }

            function updateCount() {
                const rowCount = tableBody.find('tr[data-row="1"]').length;
                categoryCount.text(rowCount);
            }

            function ensureEmptyState() {
                const rowCount = tableBody.find('tr[data-row="1"]').length;

                if (rowCount === 0) {
                    if ($('#emptyRow').length === 0) {
                        tableBody.html(`
                                <tr id="emptyRow">
                                    <td colspan="7">
                                        <div class="empty-state">
                                            <h5>Henüz kategori eklenmemiş</h5>
                                            <div>Sol taraftaki formdan ilk kaydı oluşturabilirsin.</div>
                                        </div>
                                    </td>
                                </tr>
                            `);
                    }
                } else {
                    $('#emptyRow').remove();
                }

                updateCount();
            }

            function buildStatusBadge(isOpen) {
                return isOpen
                    ? '<span class="status-ok">Açık</span>'
                    : '<span class="status-passive">Kapalı</span>';
            }

            function buildRow(item) {
                const hasRelation = item.packageCount > 0 || item.subPackageCount > 0;

                return `
                        <tr id="row-${item.id}" data-row="1">
                            <td>
                                <div class="entity-title">${escapeHtml(item.name)}</div>
                                <div class="entity-meta">ID: ${item.id}</div>
                            </td>
                            <td>
                                ${buildStatusBadge(item.isPackageMultiSelected)}
                            </td>
                            <td>
                                ${buildStatusBadge(item.isSubPackageMultiSelected)}
                            </td>
                            <td>
                                <span class="badge-soft-dark">${item.packageCount} paket</span>
                            </td>
                            <td>
                                <span class="badge-soft-dark">${item.subPackageCount} alt paket</span>
                            </td>
                            <td>
                                ${hasRelation
                        ? '<span class="status-ok">Kullanımda</span>'
                        : '<span class="status-passive">Bağlantı yok</span>'}
                            </td>
                            <td class="text-end">
                                <div class="inline-actions justify-content-end">
                                    <button type="button"
                                            class="btn btn-sm btn-outline-primary btn-category-edit"
                                            data-id="${item.id}">
                                        Düzenle
                                    </button>

                                    <button type="button"
                                            class="btn btn-sm btn-outline-danger btn-category-delete"
                                            data-id="${item.id}"
                                            ${hasRelation ? 'disabled' : ''}>
                                        Sil
                                    </button>
                                </div>
                            </td>
                        </tr>
                    `;
            }

            form.on('submit', function(e) {
                e.preventDefault();

                showFormErrors([]);
                btnSave.prop('disabled', true);

                $.ajax({
                    url: '@Url.Action("SaveAjax", "Categories", new { area = "Admin" })',
                    type: 'POST',
                    data: {
                        __RequestVerificationToken: token,
                        Id: $('#categoryId').val(),
                        Name: $('#categoryName').val(),
                        IsPackageMultiSelected: $('#isPackageMultiSelected').is(':checked'),
                        IsSubPackageMultiSelected: $('#isSubPackageMultiSelected').is(':checked')
                    },
                    success: function(response) {
                        if (!response.success) {
                            showFormErrors(response.errors || [response.message || 'İşlem başarısız oldu.']);
                            return;
                        }

                        $('#emptyRow').remove();

                        const rowHtml = buildRow(response.item);
                        const existingRow = $('#row-' + response.item.id);

                        if (existingRow.length) {
                            existingRow.replaceWith(rowHtml);
                        } else {
                            tableBody.prepend(rowHtml);
                        }

                        resetForm();
                        ensureEmptyState();
                        showPageAlert('success', response.message);
                    },
                    error: function() {
                        showPageAlert('danger', 'İşlem sırasında beklenmeyen bir hata oluştu.');
                    },
                    complete: function() {
                        btnSave.prop('disabled', false);
                    }
                });
            });

            btnCancelEdit.on('click', function() {
                resetForm();
            });

            $(document).on('click', '.btn-category-edit', function() {
                const id = $(this).data('id');

                $.ajax({
                    url: '@Url.Action("GetById", "Categories", new { area = "Admin" })',
                    type: 'GET',
                    data: { id: id },
                    success: function(response) {
                        if (!response.success) {
                            showPageAlert('danger', response.message || 'Kayıt alınamadı.');
                            return;
                        }

                        $('#categoryId').val(response.item.id);
                        $('#categoryName').val(response.item.name);
                        $('#isPackageMultiSelected').prop('checked', response.item.isPackageMultiSelected);
                        $('#isSubPackageMultiSelected').prop('checked', response.item.isSubPackageMultiSelected);
                        formTitle.text('Kategori Düzenle');
                        btnSave.text('Güncelle');
                        showFormErrors([]);

                        $('html, body').animate({
                            scrollTop: form.offset().top - 120
                        }, 300);
                    },
                    error: function() {
                        showPageAlert('danger', 'Kayıt bilgileri alınırken hata oluştu.');
                    }
                });
            });

            $(document).on('click', '.btn-category-delete', function() {
                const id = $(this).data('id');

                if (!confirm('Bu kategoriyi silmek istediğine emin misin?')) {
                    return;
                }

                $.ajax({
                    url: '@Url.Action("DeleteAjax", "Categories", new { area = "Admin" })',
                    type: 'POST',
                    data: {
                        __RequestVerificationToken: token,
                        id: id
                    },
                    success: function(response) {
                        if (!response.success) {
                            showPageAlert('danger', response.message || 'Silme işlemi başarısız oldu.');
                            return;
                        }

                        $('#row-' + response.id).remove();

                        const currentEditId = Number($('#categoryId').val() || 0);
                        if (currentEditId === response.id) {
                            resetForm();
                        }

                        ensureEmptyState();
                        showPageAlert('success', response.message);
                    },
                    error: function() {
                        showPageAlert('danger', 'Silme sırasında beklenmeyen bir hata oluştu.');
                    }
                });
            });

            ensureEmptyState();
        })();
    </script>
}